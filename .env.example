# CogitX-RAG Configuration

# ========== LLM Providers ==========
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001

# Default LLM Provider (openai or gemini)
DEFAULT_LLM_PROVIDER=gemini

# ========== Vector Stores ==========
# Active Vector Store (pinecone or faiss)
VECTOR_STORE_TYPE=faiss

# Pinecone
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=cogitx-rag
PINECONE_DIMENSION=1536

# FAISS
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIMENSION=1536

# ========== Graph Database ==========
# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ========== Memory & Caching ==========
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600

# Memory Configuration
ENABLE_SHORT_TERM_MEMORY=true
ENABLE_LONG_TERM_MEMORY=true
ENABLE_STRUCTURED_MEMORY=true

# ========== Retrieval Configuration ==========
# Vector Search
VECTOR_TOP_K=10
VECTOR_SIMILARITY_THRESHOLD=0.7

# BM25 Search
BM25_TOP_K=10
BM25_K1=1.5
BM25_B=0.75

# Graph Traversal
GRAPH_MAX_DEPTH=3
GRAPH_MAX_RESULTS=20

# Hybrid Retrieval
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.3
HYBRID_GRAPH_WEIGHT=0.2
RERANK_TOP_K=5

# ========== Context Building ==========
MAX_CONTEXT_LENGTH=8000
CONTEXT_COMPRESSION_ENABLED=true
COMPRESSION_RATIO=0.6

# ========== Query Understanding ==========
QUERY_EXPANSION_ENABLED=true
QUERY_DECOMPOSITION_ENABLED=false
MAX_SUB_QUERIES=3

# ========== API Configuration ==========
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
CORS_ORIGINS=["*"]

# ========== Slack Integration ==========
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_ENABLED=false

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/cogitx-rag.log

# ========== Monitoring ==========
METRICS_ENABLED=true
METRICS_PORT=9090

# ========== Development ==========
DEBUG=false
ENVIRONMENT=development
